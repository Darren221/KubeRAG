# KubeRAG golden Q&A dataset. One JSONL entry per line.
# Schema: {id, question, golden_answer, expected_source_files, type}
# Types: lookup (single chunk), multi_hop (combines >=2 docs), unanswerable, ambiguous.

# ---- LOOKUP (single-chunk answer, straightforward) ----
{"id": "lookup-001", "question": "What is a Pod in Kubernetes?", "golden_answer": "A Pod is the smallest deployable unit in Kubernetes. It hosts one or more containers that share storage and network namespaces and are scheduled together on the same node.", "expected_source_files": ["content/en/docs/concepts/workloads/pods/_index.md"], "type": "lookup"}
{"id": "lookup-002", "question": "What are the phases of a Pod's lifecycle?", "golden_answer": "A Pod's lifecycle phases are Pending, Running, Succeeded, Failed, and Unknown. Pending means the Pod has been accepted but containers are not yet running; Running means at least one container is running; Succeeded means all containers terminated successfully; Failed means at least one container terminated in failure; Unknown means the Pod state could not be obtained.", "expected_source_files": ["content/en/docs/concepts/workloads/pods/pod-lifecycle.md"], "type": "lookup"}
{"id": "lookup-003", "question": "What is the default Service type in Kubernetes?", "golden_answer": "The default Service type is ClusterIP, which exposes the service on an internal IP within the cluster and is only reachable from inside the cluster.", "expected_source_files": ["content/en/docs/concepts/services-networking/service.md"], "type": "lookup"}
{"id": "lookup-004", "question": "What does a readiness probe do?", "golden_answer": "A readiness probe periodically checks whether a container is ready to serve traffic. If the probe fails, the container's Pod IP is removed from the endpoints of all Services that match it, so the Pod stops receiving traffic until the probe succeeds again.", "expected_source_files": ["content/en/docs/concepts/workloads/pods/pod-lifecycle.md", "content/en/docs/tasks/configure-pod-container/configure-liveness-readiness-startup-probes.md"], "type": "lookup"}
{"id": "lookup-005", "question": "What is a ConfigMap used for?", "golden_answer": "A ConfigMap stores non-confidential configuration data as key-value pairs. Pods can consume ConfigMaps as environment variables, command-line arguments, or files in a mounted volume, allowing configuration to be decoupled from container images.", "expected_source_files": ["content/en/docs/concepts/configuration/configmap.md"], "type": "lookup"}
{"id": "lookup-006", "question": "What is a PersistentVolumeClaim?", "golden_answer": "A PersistentVolumeClaim (PVC) is a request for storage by a user. It specifies size and access modes; Kubernetes binds the claim to a matching PersistentVolume, which the Pod can then mount as a volume.", "expected_source_files": ["content/en/docs/concepts/storage/persistent-volumes.md"], "type": "lookup"}
{"id": "lookup-007", "question": "What does the kubectl port-forward command do?", "golden_answer": "kubectl port-forward forwards one or more local ports to a Pod inside the cluster. Connections to the local port are tunneled through the API server to the Pod, allowing direct access to in-cluster services without exposing them.", "expected_source_files": ["content/en/docs/tasks/access-application-cluster/port-forward-access-application-cluster.md"], "type": "lookup"}
{"id": "lookup-008", "question": "What does kubectl describe pod show?", "golden_answer": "kubectl describe pod prints detailed information about a Pod, including its current state, container conditions, events, and recent restarts. It is the primary tool for diagnosing why a Pod is in its current state.", "expected_source_files": ["content/en/docs/tasks/debug/debug-application/debug-pods.md"], "type": "lookup"}
{"id": "lookup-009", "question": "What is the role of the kube-scheduler?", "golden_answer": "The kube-scheduler watches for newly created Pods that have no assigned node and selects a node for them to run on, based on resource requirements, hardware/software constraints, affinity and anti-affinity rules, data locality, and other criteria.", "expected_source_files": ["content/en/docs/concepts/scheduling-eviction/kube-scheduler.md"], "type": "lookup"}
{"id": "lookup-010", "question": "What is a Deployment in Kubernetes?", "golden_answer": "A Deployment manages a ReplicaSet that maintains a stable set of identical Pods. It supports declarative updates, rolling rollouts, rollbacks, and scaling — providing a high-level abstraction for managing stateless applications.", "expected_source_files": ["content/en/docs/concepts/workloads/controllers/deployment.md"], "type": "lookup"}
{"id": "lookup-011", "question": "What is a Secret in Kubernetes?", "golden_answer": "A Secret holds small amounts of sensitive data such as passwords, OAuth tokens, or SSH keys. Secrets can be mounted as files in a Pod or exposed as environment variables, keeping confidential data out of the container image and Pod spec.", "expected_source_files": ["content/en/docs/concepts/configuration/secret.md"], "type": "lookup"}
{"id": "lookup-012", "question": "What is an Ingress?", "golden_answer": "An Ingress is an API object that manages external HTTP/HTTPS access to Services in the cluster. It can provide load balancing, SSL termination, and name-based virtual hosting, and is typically implemented by an Ingress controller.", "expected_source_files": ["content/en/docs/concepts/services-networking/ingress.md"], "type": "lookup"}

# ---- MULTI-HOP (requires combining >=2 docs) ----
{"id": "multihop-001", "question": "How does a readiness probe failure affect Service endpoints?", "golden_answer": "When a Pod's readiness probe fails, the kubelet marks the Pod as not ready. The endpoints controller then removes the Pod's IP from the Endpoints (and EndpointSlices) of any Service whose selector matches the Pod's labels. The Service therefore stops sending traffic to that Pod until its probe succeeds again.", "expected_source_files": ["content/en/docs/concepts/workloads/pods/pod-lifecycle.md", "content/en/docs/concepts/services-networking/service.md"], "type": "multi_hop"}
{"id": "multihop-002", "question": "What happens to a Pod's volumes when the Pod is deleted?", "golden_answer": "When a Pod is deleted, ephemeral volumes (like emptyDir) are destroyed along with it. Persistent volumes referenced via a PersistentVolumeClaim survive Pod deletion; the underlying PV remains bound to the PVC, and the reclaim policy on the PV determines what happens when the PVC is also deleted.", "expected_source_files": ["content/en/docs/concepts/storage/volumes.md", "content/en/docs/concepts/storage/persistent-volumes.md"], "type": "multi_hop"}
{"id": "multihop-003", "question": "How do Services find the Pods they route traffic to?", "golden_answer": "A Service has a label selector that matches a set of Pod labels. The endpoints controller continuously watches Pods that match the selector and updates the Service's Endpoints (or EndpointSlices) with the IPs of ready Pods. The kube-proxy on each node then uses these endpoints to route Service traffic to the Pods.", "expected_source_files": ["content/en/docs/concepts/services-networking/service.md", "content/en/docs/concepts/overview/working-with-objects/labels.md"], "type": "multi_hop"}
{"id": "multihop-004", "question": "How does a Deployment ensure rolling updates without dropping traffic?", "golden_answer": "A Deployment performs a rolling update by gradually creating Pods in a new ReplicaSet while scaling down the old ReplicaSet. Each new Pod must pass its readiness probe before the Service's endpoints controller adds its IP to the Service, and the Deployment's maxUnavailable and maxSurge fields control how many Pods can be unavailable or extra during the rollout. This combination keeps a stable set of ready Pods behind the Service throughout the update.", "expected_source_files": ["content/en/docs/concepts/workloads/controllers/deployment.md", "content/en/docs/concepts/services-networking/service.md"], "type": "multi_hop"}
{"id": "multihop-005", "question": "How do CPU and memory requests interact with Pod scheduling?", "golden_answer": "Each container in a Pod can specify resource requests for CPU and memory. The kube-scheduler uses these requests to find a node with enough allocatable capacity — it sums the requests of all Pods already on a node and only schedules a new Pod if the remaining capacity meets the new Pod's requests. Limits, by contrast, are enforced at runtime, not scheduling time.", "expected_source_files": ["content/en/docs/concepts/configuration/manage-resources-containers.md", "content/en/docs/concepts/scheduling-eviction/kube-scheduler.md"], "type": "multi_hop"}
{"id": "multihop-006", "question": "What is the relationship between a Pod's ServiceAccount and RBAC?", "golden_answer": "Each Pod runs under a ServiceAccount (default if unspecified). The ServiceAccount represents an identity inside the cluster. RBAC RoleBindings (or ClusterRoleBindings) bind a Role (or ClusterRole) to a set of subjects — which can include ServiceAccounts — controlling which API operations the Pod can perform when it uses its mounted service-account token to call the API server.", "expected_source_files": ["content/en/docs/reference/access-authn-authz/service-accounts-admin.md", "content/en/docs/reference/access-authn-authz/rbac.md"], "type": "multi_hop"}
{"id": "multihop-007", "question": "Why might a Pod be in Pending state, and how would I diagnose it?", "golden_answer": "A Pod is in Pending when the scheduler has not yet placed it on a node. The most common cause is insufficient cluster resources — exhausted CPU or memory across all nodes preventing the Pod from being scheduled. Other causes include hostPort conflicts that limit which nodes a Pod can run on. kubectl describe pod shows scheduler events explaining why the Pod cannot be scheduled.", "expected_source_files": ["content/en/docs/concepts/workloads/pods/pod-lifecycle.md", "content/en/docs/tasks/debug/debug-application/debug-pods.md"], "type": "multi_hop"}

