# Keep the build context small. Anything not needed for the runtime image
# stays out of `docker build`'s view.

# Version control
.git/
.gitignore
.gitattributes

# Local working notes (already gitignored, but doubly excluded from Docker)
LEARNING/
SPEC.md
PLAN.md
TASKS.md
Context.md
tools/

# Local environments and caches
.env
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local project data — never bake into the image
data/
eval/results/
eval/.cache/

# Tests (the runtime container doesn't run pytest)
tests/

# Dashboard intentionally NOT excluded: the dashboard image needs it.
# The API Dockerfile only COPYs src/, so dashboard/ in the build context
# doesn't end up in the API image either way.

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
*.egg-info/
