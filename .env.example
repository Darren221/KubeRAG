# Required
OPENAI_API_KEY=sk-...

# Models (pinned, do not use aliases)
KUBERAG_EMBEDDING_MODEL=text-embedding-3-small
KUBERAG_GENERATION_MODEL=gpt-4o
KUBERAG_JUDGE_MODEL=gpt-4o-mini

# Storage paths
KUBERAG_CHROMA_PATH=./data/chroma
KUBERAG_BM25_PATH=./data/bm25.pkl
KUBERAG_RAW_DOCS_PATH=./data/raw

# Retrieval / fusion knobs
KUBERAG_RETRIEVAL_K=10
KUBERAG_RRF_DENSE_WEIGHT=0.7
KUBERAG_RERANK_TOP_N=5

# Ingest knobs
KUBERAG_DEDUPE_THRESHOLD=0.95
KUBERAG_CHUNK_SIZE=800
KUBERAG_CHUNK_OVERLAP=120

# Generation knobs
KUBERAG_CONFIDENCE_THRESHOLD=0.4

# Dashboard → API URL
KUBERAG_API_URL=http://localhost:8000
